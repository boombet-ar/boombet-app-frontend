# Configuracion de entorno para Boombet App

API_HOST=tu-host-backend-aca

# Ejemplo
# API_HOST=localhost
# API_HOST=api-dev.boombet.com

# Scheme backend (http o https)
API_SCHEME=https

# Proxys para cargar imagenes y videos
IMAGE_PROXY_BASE=https://images.weserv.nl/?url=
VIDEO_PROXY_BASE=https://cors.isomorphic-git.org/

# Key para acceder a datos de usuario
USERDATA_KEY=tu-clave-secreta-aqui

# Firebase - compartidas entre plataformas
FIREBASE_PROJECT_ID=tu-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=tu-sender-id
FIREBASE_STORAGE_BUCKET=tu-project.firebasestorage.app

# Firebase - Web
FIREBASE_WEB_API_KEY=tu-web-api-key
FIREBASE_WEB_APP_ID=1:sender-id:web:app-id
FIREBASE_WEB_AUTH_DOMAIN=tu-project.firebaseapp.com
FIREBASE_WEB_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase - Android
FIREBASE_ANDROID_API_KEY=tu-android-api-key
FIREBASE_ANDROID_APP_ID=1:sender-id:android:app-id

# Firebase - iOS
FIREBASE_IOS_API_KEY=tu-ios-api-key
FIREBASE_IOS_APP_ID=1:sender-id:ios:app-id
FIREBASE_IOS_BUNDLE_ID=com.tu.app
